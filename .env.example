TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_GROUP_CHAT_ID=
# Set to true to long-poll Telegram getUpdates from inside the FastAPI process.
# Auto-receives images in TELEGRAM_GROUP_CHAT_ID and replies with analysis.
# Do NOT enable together with a Telegram webhook (mutually exclusive).
TELEGRAM_POLLING_ENABLED=false
# Set to true to skip sending messages to Telegram and instead print them to
# stdout. Useful for local testing without spamming the group.
TELEGRAM_DRY_RUN=false
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
APP_TIMEZONE=Asia/Kolkata
# Optional. If set, /api/upload, /api/summary, and /api/backfill require
# X-Admin-API-Secret with this value.
ADMIN_API_SECRET=
# Required for the Vercel cron endpoint /api/cron/daily-summary.
# Vercel auto-injects this when set in the project environment. The cron
# request arrives with `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
