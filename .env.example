TELEGRAM_BOT_TOKEN=
# Required once the bot handles private chats (DM profiles): it is the only
# authenticity boundary for that write surface. The app warns loudly if unset.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated group chat ids. Append a new id to add a group;
TELEGRAM_GROUP_CHAT_ID=
# Set to true to long-poll Telegram getUpdates from inside the FastAPI process.
# Do NOT enable together with a Telegram webhook (mutually exclusive).
TELEGRAM_POLLING_ENABLED=false
# Set to true to skip sending messages to Telegram and instead print them to
# stdout. Useful for local testing without spamming the group.
TELEGRAM_DRY_RUN=false
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Use OpenAI's flex service tier by default (~50% cheaper, but slower and can run
# out of capacity). Flex is used only for flex-capable models (gpt-5 / o-series;
# gpt-4.1 etc. always use the primary tier). A flex call runs with
# OPENAI_FLEX_TIMEOUT seconds; if it times out or hits a 429, flex is marked down
# for 30 minutes (shared across workers via Redis) and that attempt fails — the
# next call (a Telegram webhook retry, or the image tip's own fallback) uses the
# primary tier. Set false to always use the primary tier.
OPENAI_FLEX_ENABLED=true
OPENAI_FLEX_TIMEOUT=45
# Optional. YouTube Data API v3 key; when set, /recommend attaches a top recipe
# video for the first option. Without it, recommendations ship with no video.
YOUTUBE_API_KEY=
APP_TIMEZONE=Asia/Kolkata
# Optional. If set, the manual routes (/api/upload, /api/summary, /api/backfill,
# /api/meals, /api/profiles) require X-Admin-API-Secret with this value.
ADMIN_API_SECRET=
# Required for the cron endpoints /api/cron/daily-summary (21:30 IST) and
# /api/cron/streak-nudge (19:00 IST). The cron request arrives with
# `Authorization: Bearer <CRON_SECRET>`. The GitHub Actions also share a CRON_URL
# secret (the full daily-summary URL); the streak-nudge workflow derives its URL
# from it by swapping the trailing path, so no second URL is needed.
CRON_SECRET=
